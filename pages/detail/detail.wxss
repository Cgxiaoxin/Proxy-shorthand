/* 详情卡片样式 */
.detail-card {
  margin-bottom: 30rpx;
}

.detail-header {
  display: flex;
  gap: 16rpx;
  margin-bottom: 30rpx;
}

/* 状态徽章样式 */
.status-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.status-badge.completed {
  background: #E8F5E8;
  color: #2ED573;
}

.status-badge.pending {
  background: #FFF3E0;
  color: #FF9800;
}

/* 优先级徽章样式 */
.priority-badge {
  padding: 8rpx 16rpx;
  border-radius: 20rpx;
  font-size: 24rpx;
  font-weight: 500;
}

.priority-low {
  background: #E8F5E8;
  color: #2ED573;
}

.priority-medium {
  background: #FFF3E0;
  color: #FF9800;
}

.priority-high {
  background: #FFEBEE;
  color: #FF4757;
}

/* 详情内容样式 */
.detail-content {
  margin-bottom: 40rpx;
}

.detail-title {
  display: block;
  font-size: 36rpx;
  font-weight: bold;
  color: #333333;
  margin-bottom: 20rpx;
  line-height: 1.4;
}

.detail-title.completed {
  text-decoration: line-through;
  color: #999999;
}

.detail-desc {
  display: block;
  font-size: 28rpx;
  color: #666666;
  margin-bottom: 30rpx;
  line-height: 1.6;
}

/* 元信息样式 */
.detail-meta {
  border-top: 2rpx solid #F0F0F0;
  padding-top: 20rpx;
}

.meta-item {
  display: flex;
  align-items: center;
  margin-bottom: 16rpx;
}

.meta-item:last-child {
  margin-bottom: 0;
}

.meta-label {
  font-size: 26rpx;
  color: #999999;
  min-width: 140rpx;
}

.meta-value {
  font-size: 26rpx;
  color: #333333;
  flex: 1;
}

.meta-value.overdue {
  color: #FF4757;
}

.overdue-text {
  color: #FF4757;
  font-weight: 500;
}

/* 详情操作按钮样式 */
.detail-actions {
  display: flex;
  gap: 20rpx;
}

.detail-actions .btn {
  flex: 1;
}

/* 编辑表单样式 */
.edit-form {
  animation: slideIn 0.3s ease-out;
}

.edit-header {
  margin-bottom: 30rpx;
}

.edit-title {
  font-size: 32rpx;
  font-weight: bold;
  color: #333333;
}

/* 编辑操作按钮样式 */
.edit-actions {
  display: flex;
  gap: 20rpx;
  margin-top: 40rpx;
}

.edit-actions .btn {
  flex: 1;
}

/* 成功按钮样式 */
.btn-success {
  background: #2ED573;
  color: #FFFFFF;
}

.btn-success:active {
  background: #26A65B;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
  .detail-actions {
    flex-direction: column;
  }
  
  .edit-actions {
    flex-direction: column;
  }
}